# =============================================================
# MonkeyLMS — Environment Variables Template
# =============================================================
# Copy this file: cp .env.example .env
# Fill in real values before running docker compose.
# NEVER commit the .env file to version control.
# =============================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=mentorflow

# ---- Backend ----
BACKEND_PORT=8080
# DATABASE_URL is auto-constructed by docker-compose from the vars above.
# Set it here only if running backend outside Docker.
DATABASE_URL=postgres://postgres:changeme_strong_password@localhost:5433/mentorflow?sslmode=disable
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ---- Frontend (Next.js) ----
# For browser requests: this must be reachable from the user's browser.
# In Docker (same machine): http://localhost:8080
# In production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080
